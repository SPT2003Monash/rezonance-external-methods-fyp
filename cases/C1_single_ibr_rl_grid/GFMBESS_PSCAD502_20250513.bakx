    <Definition classid="UserCmpDefn" name="Grid_RL_Calc" build="" crc="63852021" view="false" instances="0" date="0" id="155496724" w="320" h="400">
      <paramlist>
        <param name="Description" value="Grid RL Calc" />
      </paramlist>
      <form name="Grid RL Calc" splitter="60" w="320" h="400" commentlines="4" help-width="490">
        <category name="Configuration" visible="true">
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" group="" type="Text" helpmode="Append" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
            <cond><![CDATA[true]]></cond>
            <help><![CDATA[The name of the component]]></help>
            <regex><![CDATA[]]></regex>
            <error_msg><![CDATA[]]></error_msg>
            <vis />
          </parameter>
          <parameter name="Sbase" desc="Sbase (MVA)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="MVA" min="-1E+308" max="1E+308">
            <value><![CDATA[400]]></value>
            <cond><![CDATA[]]></cond>
            <vis><![CDATA[]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Fnom" desc="Frequency (Hz)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="Hz" min="-1E+308" max="1E+308">
            <value><![CDATA[50]]></value>
            <cond><![CDATA[]]></cond>
            <vis><![CDATA[]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Vbase" desc="Voltage (kV)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="kV" min="-1E+308" max="1E+308">
            <value><![CDATA[500]]></value>
            <cond><![CDATA[]]></cond>
            <vis><![CDATA[]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
        </category>
      </form>
      <script>
        <segment name="Computations" id="177809684" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="1675703525" classid="CoreSegment"><![CDATA[!!!! Grid_RL_Calc
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2022-04-28


	$R = 1/$SCR/sqrt(1+($XR*$XR))*$Vbase*$Vbase/$Sbase
	$L = 1/$SCR/sqrt(1+1/($XR*$XR))*$Vbase*$Vbase/$Sbase/(2*3.141592653589793*$Fnom)]]></segment>
        <segment name="Branch" id="187267523" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
