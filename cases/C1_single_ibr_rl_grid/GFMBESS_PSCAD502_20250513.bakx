            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="C_GSC_pu" desc="GSC Capacitance (pu)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="pu" min="-1E+308" max="1E+308">
            <value><![CDATA[0.03]]></value>
