        <segment name="Computations" id="194013143" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="1925938421" classid="CoreSegment"><![CDATA[!!!! alphabeta to dq
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2022-05-31


	$d = $al * sin($Theta) - $be * cos ($Theta)

	$q = $al * cos ($Theta) + $be * sin ($Theta)]]></segment>
