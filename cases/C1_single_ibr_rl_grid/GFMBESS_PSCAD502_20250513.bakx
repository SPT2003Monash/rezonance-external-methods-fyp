    <Definition classid="UserCmpDefn" name="alphabeta0_to_abc" build="" crc="122446959" view="false" instances="0" date="0" id="2023039368" w="320" h="400" url="" group="">
      <paramlist>
        <param name="Description" value="" />
      </paramlist>
      <form name="Overspeed Curve" splitter="60">
        <category name="Configuration" visible="true">
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" group="" type="Text" helpmode="Overwrite" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
