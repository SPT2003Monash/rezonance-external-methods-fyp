    <Definition classid="UserCmpDefn" name="JVC_Gains" build="" crc="83169087" view="false" instances="0" date="0" id="371008004" w="320" h="400" url="" group="">
      <paramlist>
        <param name="Description" value="Voltage Controller Gains" />
      </paramlist>
      <form name="GVC_Gains" splitter="60" w="320" h="400" commentlines="4" help-width="490">
        <category name="Configuration" visible="true">
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" group="" type="Text" helpmode="Overwrite" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
            <cond><![CDATA[true]]></cond>
            <help><![CDATA[The name of the component]]></help>
            <regex><![CDATA[]]></regex>
            <error_msg><![CDATA[]]></error_msg>
            <vis />
          </parameter>
          <parameter name="Kcc" desc="Currect Controller Gain (rad/s)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="rad/s" min="0" max="10000">
            <value><![CDATA[1500]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="FF_GCC" desc="Currect Loop Feedforward Gain" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="-10000" max="10000">
            <value><![CDATA[1]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="wc" desc="VC Neg. Cross-over Frequency (rad/s)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="rad/s" min="0" max="200">
            <value><![CDATA[80]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="PM" desc="VC Neg. Phase Margin (deg)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="deg" min="0" max="90">
            <value><![CDATA[45]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="phi_r" desc="VC Neg.Residual Phase (deg)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="deg" min="5" max="20">
            <value><![CDATA[13]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Fnom" desc="Grid Rated Frequency (Hz)" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="Hz" min="0" max="1000">
            <value><![CDATA[50]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
        </category>
      </form>
      <script>
        <segment name="Computations" id="1728794525" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="1549608522" classid="CoreSegment"><![CDATA[!!!! JVC Gains
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2025-05-02

	
	w1 = 2*3.14159265*$Fnom
	eta_v = 1 - $FF_GCC
	Xratio = 1/($SCRmax*$L_GSC_pu)

	d_i = ((w1 - $wc)*eta_v*Xratio - $wc)/$Kcc
	d_ang = ($PM - $phi_r)*(3.14159265/180)

	d = d_i/sin (d_ang)
	d_r = d*cos (d_ang)

	$FF_GVC = 1 - d_r
	$Ki_GVC = $wc*w1*d*$SCRmax/(w1 - $wc)
	$Kp_GVC = $phi_r*(3.14159265/180)*w1*d*$SCRmax/(w1 - $wc)]]></segment>
        <segment name="Branch" id="1485349290" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
      <svg viewBox="-200 -200 200 200">
        <port model="Transfer" name="Kp_GVC" x="54" y="-18" dim="1" mode="Output" type="Real" internal="false"><![CDATA[true]]></port>
        <port model="Transfer" name="Ki_GVC" x="54" y="18" dim="1" mode="Output" type="Real" internal="false"><![CDATA[true]]></port>
        <port model="Transfer" name="C_GSC_pu" x="-54" y="0" dim="1" mode="Input" type="Real" internal="false"><![CDATA[true]]></port>
        <cond><![CDATA[true]]></cond>
        <rect x="-38" y="-35" height="71" width="77" stroke="Black" stroke-width="0.2" stroke-dasharray="None" port="" fill-style="Solid" fill-fg="White" fill-bg="White" />
