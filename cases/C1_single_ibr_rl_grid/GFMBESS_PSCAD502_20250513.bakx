    <Definition classid="UserCmpDefn" name="Harmonic_Filter" group="" url="" version="" build="" crc="131402876" instances="58" key="" view="false" date="1782788844" id="32890030">
      <paramlist name="">
        <param name="Description" value="Harmonic Filter" />
