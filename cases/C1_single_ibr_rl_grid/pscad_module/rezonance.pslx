     *BR_EA_, BR_EB_, BR_CA_, BR_CB_, BR_IA_, BR_IB_, BR_ZA_, BR_ZB_,
     *NA_, NB_, NS_, $vbase, $sys_a_sbase, $sys_b_sbase, $f_fund,
     *$sys_z_a, $sys_z_b, $Rshc, $Gopc, $RTOL,
     *$b_show_advanced, $sys_split, $frame_mode,
     *$ref_angle, $auto_init_phi_kp, $auto_init_phi_ki, $man_init_phi,
     *$auto_init_mag_kp, $auto_init_mag_ki, $man_init_mag,
     *$P_AB_out_init_mw, $Q_AB_out_init_mvar, $inject_mag,
     *$inject_cycles, $ramp_cycles, $ramp_time_min, 
     *$exc_type, $mt_mag_mode, $mt_var_random_phi, $input_mode,
     *$distrib_type, $f_lo, $f_hi, $f_res, $f_num, $fdim, $op_mode, 
     *$inject_d, $inject_q, $inject_p, $inject_n, $progress_time_res, 
     *$os_factor, "$out_name", "$arr_f_fname")]]></segment>
        <segment name="Branch" id="67773488" classid="CoreSegment"><![CDATA[
    BR_MA = $AM $A AMMETER
    BR_MB = $BM $B AMMETER

#IF ($series > 0)

  #IF ($inject_vi_type <= $RTOL)

    BR_EA = $AM $BM SOURCE 0.0
  #ELSEIF (1.0 - $inject_vi_type <= $RTOL)

    BR_S = $AM $BM  BREAKER 0.0
    BR_IB = $NS $BM BREAKER $Ropc
  #ELSE

    BR_EA = $AM $BM SOURCE 0.0
    BR_IB = $NS $BM BREAKER $Ropc
  #ENDIF

#ELSEIF ($split > 0)

    BR_S = $AM $BM BREAKER 0.0
    
    BR_ZA = $AIC $AM BREAKER $Ropc
    BR_CA = $AI $AIC BREAKER $Ropc
    BR_EA = $NS $AI SOURCE 0.0
    #IF ($inject_vi_type >= $RTOL)

    BR_IA = $NS $AM BREAKER $Ropc
    #ENDIF
    
    BR_ZB = $BIC $BM BREAKER $Ropc
    BR_CB = $BI $BIC BREAKER $Ropc
    BR_EB = $NS $BI SOURCE 0.0
    #IF ($inject_vi_type >= $RTOL)

    BR_IB = $NS $BM BREAKER $Ropc
    #ENDIF

#ELSE 
    BR_S = $AM $BM BREAKER 0.0
#ENDIF]]></segment>
        <segment classid="CoreSegment" id="340393604" name="Computations"><![CDATA[
INTEGER i_ena = 1 - enable
INTEGER i_ena_a = 1 - ena_a
INTEGER i_ena_b = 1 - ena_b
INTEGER bypass = min(i_ena + i_ena_a*i_ena_b, 1)
INTEGER i_sysplt = 1 - sys_split
INTEGER i_bypass = 1 - bypass
INTEGER series = i_bypass * i_sysplt
INTEGER split = i_bypass * sys_split


REAL vbase_lg = vbase / sqrt(3)
REAL i_a_base = sys_a_sbase / (sqrt(3) * vbase)
REAL i_b_base = sys_b_sbase / (sqrt(3) * vbase)
REAL z_a_base = vbase*vbase/sys_a_sbase
REAL z_b_base = vbase*vbase/sys_b_sbase
REAL l_a_base = z_a_base/(2*pi*f_fund)
REAL l_b_base = z_b_base/(2*pi*f_fund)
REAL Ropc = 1/max(Gopc, RTOL)]]></segment>
      </script>
