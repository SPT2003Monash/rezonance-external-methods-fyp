    <Definition classid="UserCmpDefn" name="VC_Gains" build="" crc="106613301" view="false" instances="0" date="0" id="229568290" w="320" h="400" url="" group="">
      <paramlist>
        <param name="Description" value="Voltage Controller Gains" />
      </paramlist>
      <form name="GVC_Gains" splitter="60" w="320" h="400" commentlines="4" help-width="490">
        <category name="Configuration" visible="true">
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" group="" type="Text" helpmode="Overwrite" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
            <cond><![CDATA[true]]></cond>
            <help><![CDATA[The name of the component]]></help>
            <regex><![CDATA[]]></regex>
            <error_msg><![CDATA[]]></error_msg>
            <vis />
          </parameter>
          <parameter name="Kcc" desc="Currect Controller Gain (1/s)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="1/s" min="-1E+308" max="1E+308">
            <value><![CDATA[1500]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="wm" desc="Voltage Control wm (rad/s)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="1/s" min="-1E+308" max="1E+308">
            <value><![CDATA[750]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Fnom" desc="Grid Rated Frequency (Hz)" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="Hz" min="-1E+308" max="1E+308">
            <value><![CDATA[50]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
        </category>
      </form>
      <script>
        <segment name="Computations" id="812326188" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="1327733974" classid="CoreSegment"><![CDATA[!!!! GVC Gains
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2022-05-11


	delta_m = asin ((1 - ($wm/$Kcc)**2)/(1 + ($wm/$Kcc)**2))

	$Kp_GVC = sqrt((1 - sin (delta_m))/(1 + sin (delta_m)))*$Kcc*$C_GSC_pu/(2*3.14159265*$Fnom)
	$Ki_GVC = (sqrt((1 - sin (delta_m))/(1 + sin (delta_m))))**3*($Kcc**2)*$C_GSC_pu/(2*3.14159265*$Fnom)]]></segment>
        <segment name="Branch" id="173916311" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
