      <script>
        <segment name="Computations" id="1958472574" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="1094795261" classid="CoreSegment"><![CDATA[!!!! abc to alphabeta0
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2022-05-31

	$al = 0.666666666667*($a+(-0.5)*$b+(-0.5)*$c)
	$be = 0.666666666667*((0.8660254)*$b+(-0.8660254)*$c)
	$o = 0.666666666667*((0.5)*$a+(0.5)*$b+(0.5)*$c)]]></segment>
        <segment name="Branch" id="1162256968" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
