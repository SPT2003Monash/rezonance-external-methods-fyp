      <form name="Harmonic Filter" w="320" h="400" splitter="60" commentlines="4" help-width="490">
        <category name="Configuration" visible="true" splitter="72">
          <cond />
          <parameter desc="Nominal System Frequency (Hz)" name="Fnom" group="General" unit="Hz" min="0" max="1E+308" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[50 [Hz]]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter name="Sbase" desc="MV/HV Transformer Rated Power (MVA)" type="Real" group="General" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="kV" min="-1E+308" max="1E+308">
            <value><![CDATA[360]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Vrated_MV" desc="Reticulation Rated Voltage (kV)" type="Real" group="General" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="kV" min="-1E+308" max="1E+308">
            <value><![CDATA[132]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="F_cf" desc="Cufoff Frequency (Hz)" type="Real" group="Compensation" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="Hz" min="0" max="10000000000">
            <value><![CDATA[900]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="L_GSC_pu" desc="Inverter Grid-side Inductance (pu)" type="Real" group="Compensation" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="pu" min="0" max="1E+100">
            <value><![CDATA[0.1]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
        </category>
      </form>
