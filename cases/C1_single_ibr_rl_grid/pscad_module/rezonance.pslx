        <category name="Advanced / testing" visible="true" splitter="67">
          <cond><![CDATA[b_show_advanced]]></cond>
          <parameter name="sys_z_a" desc="System A source impedance [pu]" type="Complex" group="2. Split system internal source impedance (R, X)" helpmode="Append" content_type="Literal" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[(0.01, 0.1)]]></value>
            <cond><![CDATA[(sys_split==1)]]></cond>
            <vis><![CDATA[(b_show_advanced>=1)]]></vis>
            <help><![CDATA[Internal source impedance inside RZ]]></help>
          </parameter>
          <parameter name="sys_z_b" desc="System B source impedance [pu]" type="Complex" group="2. Split system internal source impedance (R, X)" helpmode="Append" content_type="Literal" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[(0.01, 0.1)]]></value>
            <cond><![CDATA[(sys_split==1)]]></cond>
            <vis><![CDATA[(b_show_advanced>=1)]]></vis>
            <help><![CDATA[Internal source impedance inside RZ]]></help>
          </parameter>
          <parameter name="auto_init_phi_kp" desc="Start up voltage angle tracking Kp" type="Real" group="3. Split system automatic start up parameters" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[1]]></value>
            <cond><![CDATA[(sys_split==1)&&(start_mode==0)]]></cond>
            <vis><![CDATA[b_show_advanced>=1]]></vis>
            <help><![CDATA[[pu/pu]]]></help>
          </parameter>
          <parameter name="auto_init_phi_ki" desc="Start up voltage angle tracking Ki" type="Real" group="3. Split system automatic start up parameters" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[10]]></value>
            <cond><![CDATA[(sys_split==1)&&(start_mode==0)]]></cond>
            <vis><![CDATA[b_show_advanced>=1]]></vis>
            <help><![CDATA[[pu/pu]]]></help>
          </parameter>
          <parameter name="man_init_mag" desc="Initial voltage magnitude [pu]" type="Real" group="4. Split system manual start up parameters" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="1E-308" max="1E+308">
            <value><![CDATA[1.0]]></value>
            <cond><![CDATA[(sys_split==1)&&(start_mode==1)]]></cond>
            <vis><![CDATA[b_show_advanced>=1]]></vis>
            <help><![CDATA[[pu]]]></help>
