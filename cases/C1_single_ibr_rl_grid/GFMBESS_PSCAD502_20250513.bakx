      <script>
        <segment name="Computations" id="893305447" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="2063357326" classid="CoreSegment"><![CDATA[!!!! alphabeta0 to abc
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2022-05-31


	$a = $al + $o

	$b = (-0.5)*$al + (0.8660254)*$be + $o

	$c = (-0.5)*$al + (-0.8660254)*$be + $o]]></segment>
        <segment name="Branch" id="492700264" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
      <svg viewBox="-200 -200 200 200">
        <port model="Transfer" name="al" x="-54" y="-18" dim="1" mode="Input" type="Real" internal="false"><![CDATA[true]]></port>
        <port model="Transfer" name="a" x="54" y="-18" dim="1" mode="Output" type="Real" internal="false"><![CDATA[true]]></port>
