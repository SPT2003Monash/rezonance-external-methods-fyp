    <Definition classid="UserCmpDefn" name="GVSG_CGVSC_Gains" build="" crc="95115383" view="false" instances="0" date="0" id="1227535462" w="320" h="400" url="" group="">
      <paramlist>
        <param name="Description" value="GVSG/CGVSG Gains" />
      </paramlist>
      <form name="Cp" splitter="60" w="320" h="400" commentlines="4" help-width="490">
        <category name="Configuration" visible="true">
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" group="" type="Text" helpmode="Overwrite" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
            <cond><![CDATA[true]]></cond>
            <help><![CDATA[The name of the component]]></help>
            <regex><![CDATA[]]></regex>
            <error_msg><![CDATA[]]></error_msg>
            <vis />
          </parameter>
        </category>
      </form>
      <script>
        <segment name="Computations" id="1845417448" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="2046106019" classid="CoreSegment"><![CDATA[!!!! GVSG/CGVSG Gains
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2022-06-09

	beta = $tau**2 * (($SCR**2)/($D**2 * $tau) - 1)**0.333333333
	gamma = (($SCR**2)/($D**2 * $tau) - 1)**(-0.333333333)	

	$a = $tau
	$b = (beta*gamma)/(beta + gamma - $tau)
	$c = (beta + gamma - $tau)*$D]]></segment>
        <segment name="Branch" id="1281813037" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
