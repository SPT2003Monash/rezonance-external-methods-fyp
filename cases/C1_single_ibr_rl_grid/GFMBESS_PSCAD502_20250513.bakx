      <script>
        <segment name="Computations" id="509425348" classid="CoreSegment"><![CDATA[]]></segment>
        <segment name="Fortran" id="309949514" classid="CoreSegment"><![CDATA[!!!! dq to alphabeta
!!!! Scripted by MHRavanji
!!!! moh.ravanji@gmail.com
!!!! Date Modified: 2022-05-31


	$al = $d * sin($Theta) + $q * cos ($Theta)

	$be = -$d * cos ($Theta) + $q * sin ($Theta)]]></segment>
        <segment name="Branch" id="69567411" classid="CoreSegment"><![CDATA[]]></segment>
      </script>
