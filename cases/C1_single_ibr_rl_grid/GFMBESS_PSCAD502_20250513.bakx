            <value><![CDATA[2.0 [MVA]]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter name="Fnom" desc="Grid Rated Frequency" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="Hz" min="-1E+308" max="1E+308">
            <value><![CDATA[50]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Vac_nom_GSC" desc="GSC Rated AC Voltage" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="kV" min="-1E+308" max="1E+308">
            <value><![CDATA[0.65]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Vdc_nom" desc="Rated DC Voltage" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="kV" min="-1E+308" max="1E+308">
            <value><![CDATA[1.2]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="L_GSC_pu" desc="GSC Inductance (pu)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="pu" min="-1E+308" max="1E+308">
            <value><![CDATA[0.1]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="R_GSC_pu" desc="GSC Resistance (pu)" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="pu" min="-1E+308" max="1E+308">
            <value><![CDATA[0.001]]></value>
